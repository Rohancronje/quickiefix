{
  "expo": {
    "name": "QuickieFix",
    "slug": "QuickieFix",
    "version": "1.2.0",
    "scheme": "quickiefix",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "updates": {
      "url": "https://u.expo.dev/af87594c-64e6-4ab1-8796-04cf077c722b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.quickiefix",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "QuickieFix uses your location to match you with nearby jobs and detect when you arrive on site.",
        "NSPhotoLibraryUsageDescription": "QuickieFix lets you attach photos of the issue to a job request."
      }
    },
    "android": {
      "package": "app.quickiefix",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCIO-Hhe8_XwSb6j2rjDX-PTu_nicEW7S0"
        }
      },
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220",
        "foregroundImage": "./assets/adaptive-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "QuickieFix uses your location to match you with nearby jobs and detect when you arrive on site."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QuickieFix lets you attach photos of the issue to a job request."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock QuickieFix."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FFB020"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false
          }
        }
      ],
      "expo-status-bar",
      "expo-audio",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af87594c-64e6-4ab1-8796-04cf077c722b"
      }
    },
    "owner": "rohan87"
  }
}
