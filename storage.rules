rules_version = '2';

// QuickieFix Storage rules — job photos live under jobs/{jobId}/...
// Any signed-in user can read/write job photos for the MVP. For production,
// restrict writes to the job's customer and reads to the assigned parties.
service firebase.storage {
  match /b/{bucket}/o {
    match /jobs/{jobId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
