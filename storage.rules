rules_version = '2';

// QuickieFix Storage rules — job photos live under jobs/{jobId}/{uploaderUid}/…
//
// Writes are locked to the uploader (the requesting customer) so no one can
// overwrite or pollute another job's photos. Direct path READS are also locked
// to the uploader — the job's other parties (the assigned tradie, the agency)
// view photos through the tokenized download URL stored on the access
// -controlled job doc, which bypasses these rules, so nothing legitimate breaks.
service firebase.storage {
  match /b/{bucket}/o {
    match /jobs/{jobId}/{uid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
