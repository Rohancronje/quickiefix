rules_version = '2';

// QuickieFix Firestore security rules.
//
// MVP posture: authentication is required for everything, with ownership checks
// on the sensitive writes. A couple of cross-user writes the client performs
// (a customer rating a tradie) are allowed narrowly. For production you would
// move privileged transitions (accept/complete/rating aggregation) into Cloud
// Functions and tighten `jobs` updates to the assigned parties only.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Platform (back-office) admins — identified by email allowlist. Add more
    // admin emails here as needed. Must match the portal's PLATFORM_ADMINS list.
    function isPlatformAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['admin@quickiefix.store'];
    }

    match /users/{userId} {
      allow read: if signedIn();
      // You may only create your own user document (during registration).
      allow create: if signedIn() && request.auth.uid == userId;
      // Owner may update their own profile; platform admin may manage users; a
      // company admin may change ONLY the companyId/companyName of a tradie in
      // their own company (used to remove a tradie). Rating aggregates
      // (ratingAvg/ratingCount) are written ONLY by the onJobRated Cloud
      // Function via the Admin SDK — never by clients.
      allow update: if signedIn() && (
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ratingAvg', 'ratingCount', 'completedJobs', 'freeJobCredits', 'paymentHold'])
        ) ||
        isPlatformAdmin() ||
        (
          // Company admin REMOVES their tradie: clears the tag binding and
          // restores the tradie's own identity (name/NZBN for ex-employees).
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['companyId', 'companyName', 'activeTagId', 'engagement',
                      'businessName', 'nzbn', 'prevBusinessName', 'prevNzbn']) &&
          resource.data.companyId != null &&
          get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid
        ) ||
        (
          // Company admin CONFIRMS a claimed seat: may bind a tradie to their
          // own company ONLY via the claim chain — the tradie's active tag must
          // belong to this admin's company and be claimed by this tradie.
          // Employee confirms also seed the company NZBN + personal name.
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['companyId', 'companyName', 'engagement',
                      'businessName', 'nzbn', 'prevBusinessName', 'prevNzbn']) &&
          resource.data.activeTagId != null &&
          get(/databases/$(database)/documents/companyTags/$(resource.data.activeTagId)).data.claimedByUserId == userId &&
          get(/databases/$(database)/documents/companyTags/$(resource.data.activeTagId)).data.companyId == request.resource.data.companyId &&
          get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.adminUserId == request.auth.uid
        )
      );
      allow delete: if false;
    }

    // Public landing-page waitlist: anyone may add their email; only platform
    // admins can read the list back (in the back-office Waitlist tab).
    match /waitlist/{id} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 320;
      allow read: if isPlatformAdmin();
      allow update, delete: if false;
    }

    // Companies are owned by their admin (created via the web portal).
    match /companies/{companyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.adminUserId == request.auth.uid;
      // Company admin manages their own doc (rate card, billing email); platform
      // admin may manage any (e.g. shared-credit pool).
      allow update: if isPlatformAdmin() ||
        (signedIn() && resource.data.adminUserId == request.auth.uid);
      allow delete: if false;
    }

    // Maps a company-admin auth user to their company.
    match /companyAdmins/{uid} {
      allow read, create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Company tags (seats) — the tag model (§6). Replaces invites.
    match /companyTags/{id} {
      allow read: if signedIn();
      // Company admin issues seats for their own company (platform admin too).
      allow create: if isPlatformAdmin() || (signedIn()
        && get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.adminUserId == request.auth.uid);
      // Updates:
      //  - platform admin (validate / remove-override),
      //  - the owning company admin (remove), or
      //  - a tradie CLAIMING a still-issued code (sets themselves as claimer).
      allow update: if isPlatformAdmin()
        || (signedIn()
            && get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid)
        || (signedIn()
            && resource.data.status == 'issued'
            && request.resource.data.claimedByUserId == request.auth.uid);
      allow delete: if false;
    }

    // Property agencies (portal accounts). Readable by any signed-in user so
    // tradies can resolve an agent code; only the agency admin manages it.
    match /agencies/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.adminUserId == request.auth.uid;
      allow update: if isPlatformAdmin() ||
        (signedIn() && resource.data.adminUserId == request.auth.uid);
      allow delete: if false;
    }

    // Agency panel links: a tradie (or company admin) requests with the agency
    // code; ONLY the agency approves/removes. Members may create their own
    // pending request and never anything else.
    match /agencyLinks/{id} {
      function agencyAdmin(agencyId) {
        return get(/databases/$(database)/documents/agencies/$(agencyId)).data.adminUserId == request.auth.uid;
      }
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.status == 'pending'
        && (
          // A tradie or tenant linking themselves…
          (request.resource.data.kind in ['tradie', 'tenant'] && request.resource.data.memberId == request.auth.uid) ||
          // …or a company admin linking their own company.
          (request.resource.data.kind == 'company' &&
           get(/databases/$(database)/documents/companies/$(request.resource.data.memberId)).data.adminUserId == request.auth.uid)
        );
      allow update: if isPlatformAdmin() || (signedIn() && agencyAdmin(resource.data.agencyId));
      allow delete: if false;
    }

    // Properties (property-light, §2). The landlord owns the doc; linked tenants
    // (and platform admins) may read it. Only the landlord writes (add tenants).
    match /properties/{id} {
      allow read: if isPlatformAdmin() ||
        (signedIn() &&
          (resource.data.landlordId == request.auth.uid ||
           request.auth.uid in resource.data.tenantIds));
      allow create: if signedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update: if signedIn() && resource.data.landlordId == request.auth.uid;
      // The owner may remove a property. Job history is unaffected — jobs
      // carry their own copies of the property/agency stamps.
      allow delete: if signedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Complaints: a customer files about their own job; only platform admins
    // can read them all or resolve them.
    match /complaints/{id} {
      allow read: if isPlatformAdmin() ||
        (signedIn() && resource.data.customerId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if isPlatformAdmin();
      allow delete: if false;
    }

    // Password-reset rate-limit counters — written only by the Cloud Function
    // (Admin SDK). No client may read or write them.
    match /resetThrottle/{key} {
      allow read, write: if false;
    }

    // Append-only audit trail — written ONLY by Cloud Functions (Admin SDK).
    // Platform admins may read it in the back office; no client may ever write.
    match /auditLog/{id} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // Platform-fee ledger. A tradie may read their own fees; platform admins read
    // all. Writes are server-only (onJobCompleted Cloud Function via Admin SDK) —
    // clients can never create, alter, or waive a fee.
    match /feeLineItems/{id} {
      allow read: if isPlatformAdmin() ||
        (signedIn() && resource.data.tradieId == request.auth.uid);
      allow write: if false;
    }

    // In-app job messages (§7). Only the job's customer or assigned tradie (and
    // platform admins) can read/post. Text is contact-masked client-side on send.
    match /messages/{id} {
      function jobData(jid) {
        return get(/databases/$(database)/documents/jobs/$(jid)).data;
      }
      // While a job is still searching, dispatch candidates may read/post too —
      // that's the pre-accept Q&A ("ask a question before you take the job").
      allow read: if signedIn() && (
        isPlatformAdmin() ||
        jobData(resource.data.jobId).customerId == request.auth.uid ||
        jobData(resource.data.jobId).tradieId == request.auth.uid ||
        (
          jobData(resource.data.jobId).status == 'searching' &&
          request.auth.uid in jobData(resource.data.jobId).dispatch.candidateIds
        )
      );
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && (
          jobData(request.resource.data.jobId).customerId == request.auth.uid ||
          jobData(request.resource.data.jobId).tradieId == request.auth.uid ||
          (
            jobData(request.resource.data.jobId).status == 'searching' &&
            request.auth.uid in jobData(request.resource.data.jobId).dispatch.candidateIds
          )
        );
      allow update, delete: if false;
    }

    match /jobs/{jobId} {
      // Reads are limited to the parties to a job — NEVER "any signed-in user",
      // which would leak the customer's name, address and GPS coordinates to
      // anyone who can guess/share a job id. Legitimate readers:
      //  - the customer who created it,
      //  - the assigned tradie,
      //  - any tradie who was offered it (still in the dispatch pool),
      //  - the browse-and-choose selected tradie,
      //  - the managed-property landlord (owner reports),
      //  - the company admin the job is stamped to (companyId), and
      //  - the agency admin the job is stamped to (agencyId),
      //  - platform admins.
      allow read: if signedIn() && (
        isPlatformAdmin() ||
        resource.data.customerId == request.auth.uid ||
        resource.data.get('tradieId', '') == request.auth.uid ||
        request.auth.uid in resource.data.get('dispatch', {}).get('candidateIds', []) ||
        resource.data.get('selectedTradieId', '') == request.auth.uid ||
        resource.data.get('landlordId', '') == request.auth.uid ||
        (resource.data.get('companyId', '') != '' &&
          get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid) ||
        (resource.data.get('agencyId', '') != '' &&
          get(/databases/$(database)/documents/agencies/$(resource.data.agencyId)).data.adminUserId == request.auth.uid)
      );
      // A customer can only create a job under their own id.
      allow create: if signedIn() && request.auth.uid == request.resource.data.customerId;
      // Who may advance a job:
      //  - the customer who created it,
      //  - the assigned tradie,
      //  - any candidate in the dispatch pool WHILE the job is still searching
      //    (first-to-accept in auto mode; records a decline; opts into a
      //    browse-and-choose job by adding to interestedTradies), and
      //  - the tradie the customer picked in browse-and-choose (selectedTradieId)
      //    WHILE still searching — so they can accept/decline the selection even
      //    if they weren't in the original candidate pool, and
      //  - platform admins.
      // completionCode is the server-generated completion record — no client
      // (even the parties) may write it; the Cloud Function sets it (Admin SDK).
      allow update: if signedIn()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['completionCode'])
        && (
        resource.data.customerId == request.auth.uid ||
        resource.data.tradieId == request.auth.uid ||
        (
          resource.data.status == 'searching' &&
          request.auth.uid in resource.data.dispatch.candidateIds &&
          (
            // Browse-and-choose: an UNCHOSEN candidate may decline or express
            // interest, but may NOT take the job (status/tradieId) — only the
            // tradie the customer picked can (covered by the clause below).
            resource.data.get('assignmentMode', 'auto') != 'choose' ||
            resource.data.get('selectedTradieId', '') == request.auth.uid ||
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['status', 'tradieId', 'tradieName'])
          )
        ) ||
        (
          resource.data.status == 'searching' &&
          resource.data.selectedTradieId == request.auth.uid
        ) ||
        isPlatformAdmin()
      );
      allow delete: if false;
    }
  }
}
