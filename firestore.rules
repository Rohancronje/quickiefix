rules_version = '2';

// QuickieFix Firestore security rules.
//
// MVP posture: authentication is required for everything, with ownership checks
// on the sensitive writes. A couple of cross-user writes the client performs
// (a customer rating a tradie) are allowed narrowly. For production you would
// move privileged transitions (accept/complete/rating aggregation) into Cloud
// Functions and tighten `jobs` updates to the assigned parties only.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if signedIn();
      // You may only create your own user document (during registration).
      allow create: if signedIn() && request.auth.uid == userId;
      // Owner may update their own profile. Any signed-in user may update ONLY
      // a tradie's rating aggregate (needed when a customer rates a tradie).
      allow update: if signedIn() && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['ratingAvg', 'ratingCount'])
      );
      allow delete: if false;
    }

    // Public landing-page waitlist: anyone may add their email, nobody can read
    // the list back (only you, via the console/Admin SDK).
    match /waitlist/{id} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 320;
      allow read, update, delete: if false;
    }

    // Companies are owned by their admin (created via the web portal).
    match /companies/{companyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.adminUserId == request.auth.uid;
      allow update: if signedIn() && resource.data.adminUserId == request.auth.uid;
      allow delete: if false;
    }

    // Maps a company-admin auth user to their company.
    match /companyAdmins/{uid} {
      allow read, create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Invite tokens bind a tradie to a company.
    match /invites/{token} {
      allow read: if signedIn();
      // Only the owning company admin can create invites for their company.
      allow create: if signedIn()
        && get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.adminUserId == request.auth.uid;
      // A redeeming tradie (or the owning admin) may update; admin may revoke.
      allow update: if signedIn();
      allow delete: if signedIn()
        && get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.adminUserId == request.auth.uid;
    }

    match /jobs/{jobId} {
      allow read: if signedIn();
      // A customer can only create a job under their own id.
      allow create: if signedIn() && request.auth.uid == request.resource.data.customerId;
      // MVP: any signed-in user can advance a job (accept/decline/transition).
      // Tighten to the customer or assigned tradie for production.
      allow update: if signedIn();
      allow delete: if false;
    }
  }
}
